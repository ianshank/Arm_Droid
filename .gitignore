mlruns/

# Mujoco cache / temp scenes
*.xml.bak
mjcache/

# Local-only configs
config/local.yaml
config/*.local.yaml

# Training weights and datasets (large files — store in DVC or cloud storage)
weights/
data/
datasets/

# Screenshots / screen recordings
screenshots/

# Log files
*.log
logs/

# Documentation build output
docs/_build/
site/

# PlatformIO build artifacts
.pio/
firmware/arm_esp32/.pio/

# Isaac Sim / Isaac Lab build artifacts (PR-B opt-in [isaac] extra)
# Vendored URDF/MJCF/STL assets under assets/so_arm/so101/ are tracked.
# Generated USD files (URDF importer output) are build artefacts only.
assets/**/usd/*.usd
assets/**/usd/*.usda
assets/**/usd/*.usdc
.isaac_cache/
.isaac_logs/
isaac_sim_logs/
# Local Kit-app shader / scene caches (Isaac Sim writes under cwd or $HOME)
*.kit-cache/

# Arduino CLI build artifacts
arduino-build/

# Local secrets — never commit real credentials
.secrets/*.env
!.secrets/*.example
!.secrets/.gitkeep

# Local env overrides
*.local.env
