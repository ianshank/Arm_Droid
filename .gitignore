# Screenshots / screen recordings
screenshots/

# Log files
*.log
logs/

# Documentation build output
docs/_build/
site/

# PlatformIO build artifacts
.pio/
firmware/arm_esp32/.pio/

# Isaac Sim / Isaac Lab build artifacts (PR-B opt-in [isaac] extra)
# Vendored URDF/MJCF/STL assets under assets/so_arm/so101/ are tracked.
# Generated USD files (URDF importer output) are build artefacts only.
assets/**/usd/*.usd
assets/**/usd/*.usda
assets/**/usd/*.usdc
.isaac_cache/
.isaac_logs/
isaac_sim_logs/
# Local Kit-app shader / scene caches (Isaac Sim writes under cwd or $HOME)
*.kit-cache/

# Arduino CLI build artifacts
arduino-build/

# Local secrets — never commit real credentials
.secrets/*.env
!.secrets/*.example
!.secrets/.gitkeep

# Firmware headers built with --secrets-file (WiFi creds + HMAC key
# baked into C string literals). The base firmware/arm_esp32/src/
# config_generated.h is tracked and validated by codegen-check; the
# *_with_secrets.h variant is local-only and must never be committed.
# scripts/gen_firmware_config.py refuses to write secrets to the
# tracked default path; this glob is the second line of defence in
# case someone names their secrets header by hand.
firmware/arm_esp32/src/config_generated_with_secrets.h
firmware/arm_esp32/src/*_with_secrets.h

# Local env overrides
*.local.env

# Local-only project bundles / scratch artefacts (created by ad-hoc
# install / packaging scripts; never committed). The pattern is broad
# enough to keep developer-side scratchpads out of source control
# without naming each one.
armdroid_isaac_bundle.zip

# Claude Code session metadata — worktrees, plans, settings, hook state.
# All of .claude/ is local-only. Worktree content has a canonical home
# on the corresponding feature branch on origin; the rest (plans,
# settings, hook state) is purely local — back it up separately if you
# want a copy off this machine.
.claude/
