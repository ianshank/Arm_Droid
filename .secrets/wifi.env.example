# Copy this file to wifi.env and fill in your values.
# wifi.env is gitignored and must NEVER be committed.
#
# ARMDROID_WIFI_SSID   - The SSID of your WiFi network
# ARMDROID_WIFI_PASS   - The WPA2 passphrase for the network
# ARMDROID_HMAC_KEY    - Hex-encoded shared secret for HMAC-SHA256 auth.
#                        Minimum 16 bytes (32 hex chars) per HmacFramer's
#                        _MIN_KEY_BYTES; 32 bytes (64 hex chars) is the
#                        recommended size — matches the SHA-256 output
#                        width and gives full HMAC-SHA256 entropy.
#                        Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ARMDROID_TCP_PORT    - TCP port the firmware WiFi server listens on (default 3001)

ARMDROID_WIFI_SSID=
ARMDROID_WIFI_PASS=
ARMDROID_HMAC_KEY=
ARMDROID_TCP_PORT=3001
